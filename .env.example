# Which backend composes answers: anthropic | ollama | groq | none.
# anthropic (default) needs ANTHROPIC_API_KEY; ollama needs a local Ollama
# server; groq needs GROQ_API_KEY; none forces retrieval-only mode. If the
# selected provider is unavailable, DocChat falls back to retrieval-only
# instead of erroring.
LLM_PROVIDER=anthropic

# Required when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=

# Used when LLM_PROVIDER=ollama (server expected at http://localhost:11434).
OLLAMA_MODEL=llama3

# Required when LLM_PROVIDER=groq.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Max questions (POST /api/ask) per IP per hour. Unset = no limit.
# Set this when exposing the app publicly, e.g. ASK_RATE_LIMIT=30
ASK_RATE_LIMIT=

# Database. Defaults to local SQLite; docker-compose overrides this with MySQL.
DATABASE_URL=sqlite:///./docchat.db

# Retrieval settings
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=4
